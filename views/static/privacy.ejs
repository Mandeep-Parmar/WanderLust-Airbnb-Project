<% layout("layouts/boilerplate") %>

<div class="container mt-5 mb-5">

  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">

      <div class="card shadow-sm border-0 p-4">

        <h2 class="text-center mb-3">Privacy Policy</h2>
        <p class="text-center text-muted mb-4">
          Your privacy matters to us.
        </p>

        <h5 class="fw-semibold">Information Collection</h5>
        <p>
          WanderLust is an educational demo project. Basic information such as
          name, email, listings, and reviews may be stored to provide
          application functionality.
        </p>

        <h5 class="fw-semibold mt-3">Use of Information</h5>
        <p>
          The collected information is used only for authentication,
          creating listings, and writing reviews on the platform.
        </p>

        <h5 class="fw-semibold mt-3">Data Security</h5>
        <p>
          We take reasonable steps to protect user data. However, since this
          is a learning project, users should avoid sharing sensitive
          personal information.
        </p>

        <h5 class="fw-semibold mt-3">Policy Updates</h5>
        <p>
          This privacy policy may be updated as the project evolves and
          additional features are added.
        </p>

        <p class="text-center text-muted mt-4">
          Last updated: <%= new Date().getFullYear() %>
        </p>

        <a href="/listings" class="btn btn-outline-dark mt-3">
            Back to Listings
        </a>

      </div>

    </div>
  </div>
</div>