<% layout("layouts/boilerplate") %>

<div class="filters-wrapper">
    <div class="filters mt-3">

        <a href="/listings" class="filter <%= !category ? 'active-filter' : '' %>">
            <i class="fa-solid fa-border-all"></i>
            <span>All</span>
        </a>

        <a href="/listings?category=beach" class="filter <%= category==='beach' ? 'active-filter' : '' %>">
            <i class="fa-solid fa-umbrella-beach"></i>
            <span>Beach</span>
        </a>

        <a href="/listings?category=mountain" class="filter <%= category==='mountain' ? 'active-filter' : '' %>">
            <i class="fa-solid fa-mountain"></i>
            <span>Mountain</span>
        </a>

        <a href="/listings?category=city" class="filter <%= category==='city' ? 'active-filter' : '' %>">
            <i class="fa-solid fa-city"></i>
            <span>City</span>
        </a>

        <a href="/listings?category=camping" class="filter <%= category==='camping' ? 'active-filter' : '' %>">
            <i class="fa-solid fa-campground"></i>
            <span>Camping</span>
        </a>

        <a href="/listings?category=rooms" class="filter <%= category==='rooms' ? 'active-filter' : '' %>">
            <i class="fa-solid fa-bed"></i>
            <span>Rooms</span>
        </a>

        <a href="/listings?category=farm" class="filter <%= category==='farm' ? 'active-filter' : '' %>">
            <i class="fa-solid fa-tractor"></i>
            <span>Farm</span>
        </a>
    </div>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Tax</label>
        </div>
    </div>
</div>


<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for (let listing of listings) {%>
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image">
                <div class="card-body" >
                    <p class="card-title"><b><%= listing.title %></b></p>
                    <p class="card-location"><%= listing.location %>, <%= listing.country %></p>
                    <p class="card-price">
                        &#8377 
                        <span class="price" data-price="<%= listing.price %>">
                            <%= listing.price.toLocaleString("en-IN") %>
                        </span> / night
                        <i class="tax-info"> &nbsp; &nbsp; Includes 18% GST </i>
                    </p>
                </div>
            </div>
        </a>
    <% } %>
</div>