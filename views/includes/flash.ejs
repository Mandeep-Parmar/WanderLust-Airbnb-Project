<% if(success && success.length) { %>
    <div class="row justify-content-center">
        <div class="alert alert-success alert-dismissible fade show col-lg-6 col-md-10 mt-3 mb-3 text-center" role="alert">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
<% } %>

<% if(error && error.length) { %>
    <div class="row justify-content-center">
        <div class="alert alert-danger alert-dismissible fade show col-lg-6 col-md-10 mt-3 mb-3 text-center" role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
<% } %>